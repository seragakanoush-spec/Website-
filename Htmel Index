<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Studio Serag | Architecture Portfolio</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="style.css">
</head>
<body>

<nav>
  <a href="#" class="logo">STUDIO SERAG</a>
  <button class="menu-toggle" aria-label="Menu" aria-expanded="false"><i class="fas fa-bars"></i></button>
  <ul class="nav-links">
    <li><a href="#work">Work</a></li>
    <li><a href="#about">Studio</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="container hero-content">
    <h2>Designing Timeless<br>Architecture</h2>
    <p>Architecture Engineer | Modern • Minimal • Functional</p>
  </div>
</section>

<section id="work">
  <div class="container">
    <h2 class="section-title fade-up">Selected Work</h2>
    <div class="projects-grid" id="projectsGrid"></div>
  </div>
</section>

<section id="about">
  <div class="container">
    <h2 class="section-title fade-up">Studio</h2>
    <div class="about-text fade-up">
      <p>We design architecture that responds to context, function, and human experience. Our approach blends minimalism with precision, delivering spaces that are both aesthetically refined and highly functional.</p>
      <br>
      <p>Based in Cairo, working globally — we believe every project tells a unique story through light, material, and form.</p>
    </div>
  </div>
</section>

<section id="contact">
  <div class="container">
    <h2 class="section-title fade-up">Contact</h2>
    <div class="contact-form fade-up">
      <form id="contactForm" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST">
        <div class="form-group">
          <input type="text" name="name" placeholder="Your Name" required>
        </div>
        <div class="form-group">
          <input type="email" name="email" placeholder="Email Address" required>
        </div>
        <div class="form-group">
          <textarea name="message" rows="5" placeholder="Tell us about your project..." required></textarea>
        </div>
        <button type="submit" class="btn">Submit Inquiry</button>
        <div class="form-status" id="formStatus"></div>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="social-links">
    <a href="#" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
    <a href="#" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
    <a href="#" aria-label="Behance"><i class="fab fa-behance"></i></a>
  </div>
  <p>© 2026 STUDIO SERAG — Architecture & Design</p>
</footer>

<button class="back-to-top" aria-label="Back to top"><i class="fas fa-arrow-up"></i></button>

<div id="lightbox" class="lightbox">
  <span class="lightbox-close">&times;</span>
  <div class="lightbox-content">
    <img class="lightbox-img" src="" alt="Project enlarged view">
  </div>
</div>

<script src="script.js"></script>
</body>
</html>