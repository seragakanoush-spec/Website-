<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Your Name | Architecture Studio</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
}

body {
    background: #0e0e0e;
    color: #eaeaea;
    overflow-x: hidden;
}

/* NAV */
nav {
    position: fixed;
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 25px 60px;
    z-index: 1000;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(10px);
}

nav h1 {
    font-weight: 400;
    letter-spacing: 2px;
}

nav a {
    color: #aaa;
    text-decoration: none;
    margin-left: 30px;
    font-size: 14px;
}

/* HERO */
.hero {
    height: 100vh;
    background: url('https://images.unsplash.com/photo-1503387762-592deb58ef4e') center/cover no-repeat;
    display: flex;
    align-items: flex-end;
    padding: 80px;
}

.hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, #000, transparent);
}

.hero-content {
    position: relative;
    max-width: 600px;
}

.hero h2 {
    font-size: 64px;
    font-weight: 300;
    line-height: 1.1;
}

.hero p {
    margin-top: 20px;
    color: #bbb;
}

/* SECTION */
section {
    padding: 120px 80px;
}

/* PROJECT GRID */
.projects {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px;
}

.project {
    position: relative;
    overflow: hidden;
}

.project img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    transition: 0.5s;
}

.project:hover img {
    transform: scale(1.05);
}

.project-title {
    position: absolute;
    bottom: 20px;
    left: 20px;
    font-size: 18px;
}

/* ABOUT */
.about {
    max-width: 700px;
    line-height: 1.8;
    color: #bbb;
}

/* CONTACT */
.contact {
    max-width: 500px;
}

.contact input, .contact textarea {
    width: 100%;
    margin-bottom: 15px;
    padding: 12px;
    background: transparent;
    border: 1px solid #333;
    color: white;
}

button {
    padding: 12px 25px;
    background: white;
    color: black;
    border: none;
    cursor: pointer;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 40px;
    border-top: 1px solid #222;
    color: #666;
}
</style>
</head>

<body>

<nav>
    <h1>YOUR NAME</h1>
    <div>
        <a href="#work">Work</a>
        <a href="#about">Studio</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<!-- HERO -->
<div class="hero">
    <div class="hero-content">
        <h2>Designing Timeless Architecture</h2>
        <p>Architecture Engineer | Modern • Minimal • Functional</p>
    </div>
</div>

<!-- PROJECTS -->
<section id="work">
    <h2 style="margin-bottom:60px; font-weight:300;">Selected Work</h2>

    <div class="projects">

        <div class="project">
            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c">
            <div class="project-title">Private Villa</div>
        </div>

        <div class="project">
            <img src="https://images.unsplash.com/photo-1494526585095-c41746248156">
            <div class="project-title">Urban Residence</div>
        </div>

        <div class="project">
            <img src="https://images.unsplash.com/photo-1501594907352-04cda38ebc29">
            <div class="project-title">Commercial Complex</div>
        </div>

        <div class="project">
            <img src="https://images.unsplash.com/photo-1487958449943-2429e8be8625">
            <div class="project-title">Cultural Center</div>
        </div>

    </div>
</section>

<!-- ABOUT -->
<section id="about">
    <h2 style="margin-bottom:40px; font-weight:300;">Studio</h2>
    <p class="about">
        We design architecture that responds to context, function, and human experience.
        Our approach blends minimalism with precision, delivering spaces that are both
        aesthetically refined and highly functional.
    </p>
</section>

<!-- CONTACT -->
<section id="contact">
    <h2 style="margin-bottom:40px; font-weight:300;">Contact</h2>

    <div class="contact">
        <input type="text" placeholder="Name">
        <input type="email" placeholder="Email">
        <textarea rows="5" placeholder="Project details"></textarea>
        <button onclick="sendMessage()">Submit Inquiry</button>
    </div>
</section>

<footer>
    © 2026 YOUR NAME — Architecture Studio
</footer>

<script>
function sendMessage() {
    alert("Inquiry submitted — connect this to backend later");
}
</script>

</body>
</html>